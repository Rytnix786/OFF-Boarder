generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                       String                    @id @default(cuid())
  name                     String
  slug                     String                    @unique
  logoUrl                  String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  status                   OrgStatus                 @default(PENDING)
  approvedAt               DateTime?
  approvedBy               String?
  rejectionReason          String?
  analyticsSnapshots       AnalyticsSnapshot[]
  assets                   Asset[]
  auditLogs                AuditLog[]
  blockedIPs               BlockedIP[]
  customRoles              CustomRole[]
  departments              Department[]
  employees                Employee[]
  employeeAttestations     EmployeeAttestation[]
  employeePortalInvites    EmployeePortalInvite[]
  employeeUserLinks        EmployeeUserLink[]
  employeeSecurityProfiles EmployeeSecurityProfile[]
  integrations             Integration[]
  invitations              Invitation[]
  jobTitles                JobTitle[]
  joinRequests             JoinRequest[]
  locations                Location[]
  memberships              Membership[]
  monitoringEvents         MonitoringEvent[]
  offboardings             Offboarding[]
  policyEnforcementLogs    PolicyEnforcementLog[]
  securityPolicies         SecurityPolicy[]
  userSessions             UserSession[]
  workflowTemplates        WorkflowTemplate[]
}

model User {
  id                            String                 @id @default(cuid())
  supabaseId                    String                 @unique
  email                         String                 @unique
  name                          String?
  avatarUrl                     String?
  createdAt                     DateTime               @default(now())
  updatedAt                     DateTime               @updatedAt
  isPlatformAdmin               Boolean                @default(false)
  passwordVersion               Int                    @default(1)
  roleVersion                   Int                    @default(1)
  lastPasswordChangeAt          DateTime?
  forceReauthAt                 DateTime?
  approvals                     Approval[]
  assetReturnProofs             AssetReturnProof[]
  auditLogs                     AuditLog[]
  blockedIPs                    BlockedIP[]            @relation("BlockedIPCreator")
  blockedAttempts               BlockedIPAttempt[]     @relation("BlockedAttemptUser")
  employeeAttestations          EmployeeAttestation[]
  acceptedEmployeePortalInvites EmployeePortalInvite[] @relation("EmployeeInviteAcceptedBy")
  sentEmployeePortalInvites     EmployeePortalInvite[] @relation("EmployeeInvitedBy")
  linkedByEmployeeUserLinks     EmployeeUserLink[]     @relation("LinkedByUser")
  employeeUserLinks             EmployeeUserLink[]
  acceptedInvitations           Invitation[]           @relation("AcceptedBy")
  sentInvitations               Invitation[]           @relation("InvitedBy")
  joinRequestsCreated           JoinRequest[]          @relation("JoinRequestRequester")
  joinRequestsResolved          JoinRequest[]          @relation("JoinRequestResolver")
  memberships                   Membership[]
  sessions                      UserSession[]
}

model Membership {
  id              String                     @id @default(cuid())
  userId          String
  organizationId  String
  systemRole      SystemRole                 @default(CONTRIBUTOR)
  requestedRole   SystemRole?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  approvedAt      DateTime?
  approvedBy      String?
  invitedBy       String?
  status          MembershipStatus           @default(PENDING)
  organization    Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleAssignments MembershipRoleAssignment[]

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
}

model Invitation {
  id               String           @id @default(cuid())
  email            String
  organizationId   String
  systemRole       SystemRole       @default(CONTRIBUTOR)
  customRoleId     String?
  token            String           @unique
  status           InvitationStatus @default(PENDING)
  expiresAt        DateTime
  invitedById      String
  acceptedAt       DateTime?
  acceptedByUserId String?
  createdAt        DateTime         @default(now())
  acceptedBy       User?            @relation("AcceptedBy", fields: [acceptedByUserId], references: [id])
  customRole       CustomRole?      @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  invitedBy        User             @relation("InvitedBy", fields: [invitedById], references: [id])
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@index([token])
  @@index([customRoleId])
}

model Integration {
  id             String       @id @default(cuid())
  organizationId String
  type           String
  name           String
  status         String       @default("disconnected")
  config         Json?
  lastSyncAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, type])
  @@index([organizationId])
}

model Department {
  id             String       @id @default(cuid())
  name           String
  description    String?
  organizationId String
  parentId       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent         Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children       Department[] @relation("DepartmentHierarchy")
  employees      Employee[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model JobTitle {
  id             String       @id @default(cuid())
  title          String
  level          Int?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  employees      Employee[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, title])
  @@index([organizationId])
}

model Location {
  id             String       @id @default(cuid())
  name           String
  address        String?
  city           String?
  country        String?
  timezone       String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  employees      Employee[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Employee {
  id                    String                    @id @default(cuid())
  employeeId            String
  firstName             String
  lastName              String
  email                 String
  phone                 String?
  hireDate              DateTime?
  status                EmployeeStatus            @default(ACTIVE)
  organizationId        String
  departmentId          String?
  jobTitleId            String?
  locationId            String?
  managerId             String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  archivedAt            DateTime?
  archivedReason        String?
  assets                Asset[]
  blockedIPs            BlockedIP[]
  department            Department?               @relation(fields: [departmentId], references: [id])
  jobTitle              JobTitle?                 @relation(fields: [jobTitleId], references: [id])
  location              Location?                 @relation(fields: [locationId], references: [id])
  manager               Employee?                 @relation("EmployeeHierarchy", fields: [managerId], references: [id])
  directReports         Employee[]                @relation("EmployeeHierarchy")
  organization          Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employeeAttestations  EmployeeAttestation[]
  employeePortalInvites EmployeePortalInvite[]
  employeeUserLinks     EmployeeUserLink[]
  offboardings          Offboarding[]
  securityProfile       EmployeeSecurityProfile?

  @@unique([organizationId, employeeId])
  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([departmentId])
  @@index([managerId])
}

model Permission {
  id              String                 @id @default(cuid())
  code            String                 @unique
  name            String
  description     String?
  category        String?
  createdAt       DateTime               @default(now())
  rolePermissions CustomRolePermission[]
}

model CustomRole {
  id             String                     @id @default(cuid())
  name           String
  description    String?
  organizationId String
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  organization   Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissions    CustomRolePermission[]
  assignments    MembershipRoleAssignment[]
  invitations    Invitation[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model CustomRolePermission {
  id           String     @id @default(cuid())
  customRoleId String
  permissionId String
  createdAt    DateTime   @default(now())
  customRole   CustomRole @relation(fields: [customRoleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([customRoleId, permissionId])
}

model MembershipRoleAssignment {
  id           String     @id @default(cuid())
  membershipId String
  customRoleId String
  createdAt    DateTime   @default(now())
  customRole   CustomRole @relation(fields: [customRoleId], references: [id], onDelete: Cascade)
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, customRoleId])
}

model AuditLog {
  id             String        @id @default(cuid())
  action         String
  entityType     String
  entityId       String?
  oldData        Json?
  newData        Json?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  organizationId String?
  userId         String?
  scope          String?       @default("ORGANIZATION")
  createdAt      DateTime      @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([scope])
}

model Offboarding {
  id                  String                @id @default(cuid())
  employeeId          String
  organizationId      String
  status              OffboardingStatus     @default(PENDING)
  scheduledDate       DateTime?
  completedDate       DateTime?
  reason              String?
  notes               String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  riskLevel           String?               @default("NORMAL")
  riskReason          String?
  riskAssessedAt      DateTime?             @db.Timestamp(6)
  riskAssessedBy      String?
  workflowTemplateId  String?
  templateVersionUsed Json?
  isLockedDown        Boolean?              @default(false)
  lockedDownAt        DateTime?
  lockedDownBy        String?
  lockedDownReason    String?
  isEscalated         Boolean?              @default(false)
  escalatedAt         DateTime?
  escalatedBy         String?
  escalationReason    String?
  requiredApprovals   Int?                  @default(1)
  accessRevocations   AccessRevocation[]
  approvals           Approval[]
  assetReturns        AssetReturn[]
  attestations        EmployeeAttestation[]
  evidencePack        EvidencePack?
  monitoringEvents    MonitoringEvent[]
  employee            Employee              @relation(fields: [employeeId], references: [id])
  organization        Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflowTemplate    WorkflowTemplate?     @relation(fields: [workflowTemplateId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tasks               OffboardingTask[]
  riskScore           RiskScore?

  @@index([organizationId])
  @@index([employeeId])
  @@index([status])
  @@index([riskLevel])
}

model OffboardingTask {
  id                   String              @id @default(cuid())
  offboardingId        String
  name                 String
  description          String?
  status               TaskStatus          @default(PENDING)
  dueDate              DateTime?
  completedAt          DateTime?
  completedBy          String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  category             String?
  requiresApproval     Boolean             @default(false)
  isHighRiskTask       Boolean             @default(false)
  isEmployeeRequired   Boolean             @default(false)
  order                Int                 @default(0)
  assignedToUserId     String?
  assignedToEmployeeId String?
  evidenceRequirement  EvidenceRequirement @default(NONE)
  approvals            Approval[]
  offboarding          Offboarding         @relation(fields: [offboardingId], references: [id], onDelete: Cascade)
  evidence             TaskEvidence[]

  @@index([offboardingId])
  @@index([assignedToUserId])
  @@index([assignedToEmployeeId])
}

model Approval {
  id              String           @id @default(cuid())
  offboardingId   String
  taskId          String?
  type            ApprovalType     @default(TASK)
  status          ApprovalStatus   @default(PENDING)
  requiredCount   Int              @default(1)
  approvalOrder   Int              @default(0)
  approverId      String?
  approvedAt      DateTime?        @db.Timestamp(6)
  rejectedAt      DateTime?        @db.Timestamp(6)
  rejectionReason String?
  comments        String?
  createdAt       DateTime         @default(now()) @db.Timestamp(6)
  updatedAt       DateTime         @default(now()) @updatedAt @db.Timestamp(6)
  approver        User?            @relation(fields: [approverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  offboarding     Offboarding      @relation(fields: [offboardingId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  task            OffboardingTask? @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([offboardingId])
  @@index([taskId])
  @@index([status])
}

model Asset {
  id             String        @id @default(cuid())
  organizationId String
  employeeId     String?
  name           String
  type           AssetType     @default(OTHER)
  serialNumber   String?
  assetTag       String?
  description    String?
  value          Float?
  purchaseDate   DateTime?     @db.Timestamp(6)
  status         AssetStatus   @default(ASSIGNED)
  notes          String?
  createdAt      DateTime      @default(now()) @db.Timestamp(6)
  updatedAt      DateTime      @default(now()) @updatedAt @db.Timestamp(6)
  employee       Employee?     @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  assetReturns   AssetReturn[]

  @@index([organizationId])
  @@index([employeeId])
  @@index([status])
  @@index([type])
}

model AssetReturn {
  id              String             @id @default(cuid())
  offboardingId   String
  assetId         String
  status          AssetReturnStatus  @default(PENDING)
  returnedAt      DateTime?          @db.Timestamp(6)
  receivedBy      String?
  condition       String?
  notes           String?
  requiresReplace Boolean            @default(false)
  createdAt       DateTime           @default(now()) @db.Timestamp(6)
  updatedAt       DateTime           @default(now()) @updatedAt @db.Timestamp(6)
  asset           Asset              @relation(fields: [assetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  offboarding     Offboarding        @relation(fields: [offboardingId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  proofs          AssetReturnProof[]

  @@unique([offboardingId, assetId])
  @@index([offboardingId])
  @@index([assetId])
  @@index([status])
}

model EvidencePack {
  id                  String                  @id @default(cuid())
  offboardingId       String                  @unique
  generatedAt         DateTime                @default(now()) @db.Timestamp(6)
  generatedBy         String?
  checksum            String?
  contentHash         String?
  data                Json
  accessLog           Json?
  createdAt           DateTime                @default(now()) @db.Timestamp(6)
  sealed              Boolean?                @default(false)
  sealedAt            DateTime?
  version             Int                     @default(1)
  evidenceManifest    Json?
  chainOfCustody      Json?
  embeddedFilesCount  Int                     @default(0)
  totalEvidenceItems  Int                     @default(0)
  offboarding         Offboarding             @relation(fields: [offboardingId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  generations         EvidencePackGeneration[]

  @@index([offboardingId])
}

model EvidencePackGeneration {
  id               String       @id @default(cuid())
  evidencePackId   String
  version          Int
  generatedAt      DateTime     @default(now()) @db.Timestamp(6)
  generatedBy      String
  generatorName    String?
  generatorEmail   String?
  ipAddress        String?
  userAgent        String?
  checksum         String
  contentHash      String
  fileSize         Int?
  pageCount        Int?
  evidenceItems    Json
  embeddedFiles    Json?
  chainOfCustody   Json
  isAuditGrade     Boolean      @default(true)
  createdAt        DateTime     @default(now()) @db.Timestamp(6)
  evidencePack     EvidencePack @relation(fields: [evidencePackId], references: [id], onDelete: Cascade)

  @@index([evidencePackId])
  @@index([generatedAt])
  @@index([generatedBy])
}

model TaskEvidence {
  id              String            @id @default(cuid())
  taskId          String
  offboardingId   String
  organizationId  String
  type            EvidenceType
  title           String?
  description     String?
  fileName        String?
  fileUrl         String?
  fileSize        Int?
  fileHash        String?
  mimeType        String?
  linkUrl         String?
  noteContent     String?
  systemProof     Json?
  metadata        Json?
  createdByUserId String
  createdAt       DateTime          @default(now()) @db.Timestamp(6)
  ipAddress       String?
  userAgent       String?
  isImmutable     Boolean           @default(false)
  immutableAt     DateTime?
  task            OffboardingTask   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([offboardingId])
  @@index([organizationId])
  @@index([createdByUserId])
  @@index([type])
}

model RiskScore {
  id             String      @id @default(cuid())
  offboardingId  String      @unique
  organizationId String
  score          Int         @default(0)
  level          RiskLevel   @default(NORMAL)
  factors        Json
  calculatedAt   DateTime    @default(now())
  calculatedBy   String?
  previousScore  Int?
  previousLevel  RiskLevel?
  changeReason   String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  offboarding    Offboarding @relation(fields: [offboardingId], references: [id], onDelete: Cascade)

  @@index([offboardingId])
  @@index([organizationId])
  @@index([level])
  @@index([score])
}

model SecurityEvent {
  id             String            @id @default(cuid())
  offboardingId  String?
  organizationId String
  employeeId     String?
  eventType      SecurityEventType
  description    String
  ipAddress      String?
  userAgent      String?
  metadata       Json?
  resolved       Boolean           @default(false)
  resolvedAt     DateTime?
  resolvedBy     String?
  createdAt      DateTime          @default(now())

  @@index([offboardingId])
  @@index([organizationId])
  @@index([employeeId])
  @@index([eventType])
  @@index([createdAt])
}

model AccessRevocation {
  id             String           @id @default(cuid())
  offboardingId  String
  organizationId String
  systemName     String
  systemType     String?
  status         RevocationStatus @default(PENDING)
  confirmedAt    DateTime?
  confirmedBy    String?
  failureReason  String?
  notes          String?
  isUrgent       Boolean          @default(false)
  dueDate        DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  offboarding    Offboarding      @relation(fields: [offboardingId], references: [id], onDelete: Cascade)

  @@index([offboardingId])
  @@index([organizationId])
  @@index([status])
}

model UserLockdown {
  id             String    @id @default(cuid())
  employeeId     String
  organizationId String
  offboardingId  String?
  reason         String
  lockedAt       DateTime  @default(now())
  lockedBy       String
  unlockedAt     DateTime?
  unlockedBy     String?
  unlockedReason String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([employeeId])
  @@index([organizationId])
  @@index([offboardingId])
  @@index([isActive])
}

model MonitoringEvent {
  id             String              @id @default(cuid())
  offboardingId  String
  organizationId String
  eventType      MonitoringEventType
  severity       MonitoringSeverity  @default(MEDIUM)
  description    String
  source         String?
  ipAddress      String?
  userAgent      String?
  metadata       Json?
  acknowledged   Boolean             @default(false)
  acknowledgedBy String?
  acknowledgedAt DateTime?           @db.Timestamp(6)
  createdAt      DateTime            @default(now()) @db.Timestamp(6)
  offboarding    Offboarding         @relation(fields: [offboardingId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([offboardingId])
  @@index([organizationId])
  @@index([eventType])
  @@index([severity])
  @@index([createdAt])
}

model WorkflowTemplate {
  id             String                 @id @default(cuid())
  organizationId String
  name           String
  description    String?
  isDefault      Boolean                @default(false)
  isActive       Boolean                @default(true)
  version        Int                    @default(1)
  config         Json
  createdAt      DateTime               @default(now()) @db.Timestamp(6)
  updatedAt      DateTime               @default(now()) @updatedAt @db.Timestamp(6)
  offboardings   Offboarding[]
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tasks          WorkflowTemplateTask[]

  @@index([organizationId])
  @@index([isDefault])
}

model WorkflowTemplateTask {
  id                  String              @id @default(cuid())
  workflowTemplateId  String
  name                String
  description         String?
  category            String?
  defaultDueDays      Int?
  requiresApproval    Boolean             @default(false)
  isHighRiskTask      Boolean             @default(false)
  order               Int                 @default(0)
  assigneeRole        String?
  assigneeDepartment  String?
  createdAt           DateTime            @default(now()) @db.Timestamp(6)
  updatedAt           DateTime            @default(now()) @updatedAt @db.Timestamp(6)
  isRequired          Boolean             @default(true)
  evidenceRequirement EvidenceRequirement @default(NONE)
  workflowTemplate    WorkflowTemplate    @relation(fields: [workflowTemplateId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([workflowTemplateId])
}

model BlockedIP {
  id              String             @id @default(cuid())
  ipAddress       String
  scope           BlockScope         @default(ORGANIZATION)
  organizationId  String?
  employeeId      String?
  offboardingOnly Boolean            @default(false)
  reason          String?
  expiresAt       DateTime?
  isActive        Boolean            @default(true)
  createdById     String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  createdBy       User               @relation("BlockedIPCreator", fields: [createdById], references: [id])
  organization    Organization?      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee        Employee?          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  attempts        BlockedIPAttempt[]

  @@index([ipAddress])
  @@index([organizationId])
  @@index([employeeId])
  @@index([scope])
  @@index([isActive])
}

model BlockedIPAttempt {
  id          String     @id @default(cuid())
  ipAddress   String
  blockedIPId String?
  path        String?
  method      String?
  userId      String?
  userAgent   String?
  createdAt   DateTime   @default(now())
  blockedIP   BlockedIP? @relation(fields: [blockedIPId], references: [id])
  user        User?      @relation("BlockedAttemptUser", fields: [userId], references: [id])

  @@index([ipAddress])
  @@index([createdAt])
}

model EmployeeUserLink {
  id             String                 @id @default(cuid())
  organizationId String
  employeeId     String
  userId         String
  portalType     PortalType             @default(SUBJECT_PORTAL)
  status         EmployeeUserLinkStatus @default(PENDING_VERIFICATION)
  linkedAt       DateTime               @default(now())
  linkedByUserId String?
  verifiedAt     DateTime?
  revokedAt      DateTime?
  revokedReason  String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  employee       Employee               @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  linkedBy       User?                  @relation("LinkedByUser", fields: [linkedByUserId], references: [id])
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@unique([organizationId, employeeId])
  @@index([userId])
  @@index([employeeId])
  @@index([status])
}

model EmployeePortalInvite {
  id               String                     @id @default(cuid())
  organizationId   String
  employeeId       String
  email            String
  token            String                     @unique
  portalType       PortalType                 @default(SUBJECT_PORTAL)
  status           EmployeePortalInviteStatus @default(PENDING)
  expiresAt        DateTime
  invitedById      String
  acceptedAt       DateTime?
  acceptedByUserId String?
  createdAt        DateTime                   @default(now())
  acceptedBy       User?                      @relation("EmployeeInviteAcceptedBy", fields: [acceptedByUserId], references: [id])
  employee         Employee                   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  invitedBy        User                       @relation("EmployeeInvitedBy", fields: [invitedById], references: [id])
  organization     Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([employeeId])
  @@index([email])
  @@index([token])
}

model EmployeeAttestation {
  id             String       @id @default(cuid())
  offboardingId  String
  employeeId     String
  organizationId String
  statement      String
  signedAt       DateTime     @default(now())
  signedByUserId String
  ipAddress      String?
  userAgent      String?
  metadata       Json?
  createdAt      DateTime     @default(now())
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  offboarding    Offboarding  @relation(fields: [offboardingId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  signedBy       User         @relation(fields: [signedByUserId], references: [id])

  @@unique([offboardingId, employeeId])
  @@index([offboardingId])
  @@index([employeeId])
  @@index([organizationId])
}

model AssetReturnProof {
  id             String         @id @default(cuid())
  assetReturnId  String
  type           AssetProofType
  fileName       String?
  fileUrl        String?
  trackingNumber String?
  description    String?
  uploadedById   String
  uploadedAt     DateTime       @default(now())
  createdAt      DateTime       @default(now())
  assetReturn    AssetReturn    @relation(fields: [assetReturnId], references: [id], onDelete: Cascade)
  uploadedBy     User           @relation(fields: [uploadedById], references: [id])

  @@index([assetReturnId])
}

model AnalyticsSnapshot {
  id                          String       @id @default(cuid())
  organizationId              String
  snapshotDate                DateTime     @default(dbgenerated("CURRENT_DATE")) @db.Date
  totalOffboardings           Int          @default(0)
  activeOffboardings          Int          @default(0)
  completedOffboardings       Int          @default(0)
  cancelledOffboardings       Int          @default(0)
  pendingOffboardings         Int          @default(0)
  inProgressOffboardings      Int          @default(0)
  pendingApprovalOffboardings Int          @default(0)
  normalRiskCount             Int          @default(0)
  highRiskCount               Int          @default(0)
  criticalRiskCount           Int          @default(0)
  completedThisMonth          Int          @default(0)
  overdueTasks                Int          @default(0)
  averageCompletionDays       Float        @default(0)
  monthlyTrend                Json?
  createdAt                   DateTime     @default(now())
  updatedAt                   DateTime     @default(now()) @updatedAt
  organization                Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([organizationId, snapshotDate])
  @@index([organizationId])
}

model Notification {
  id             String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId         String
  organizationId String
  type           String
  title          String
  message        String
  link           String?
  read           Boolean  @default(false)
  createdAt      DateTime @default(now()) @db.Timestamptz(6)

  @@index([organizationId])
  @@index([read])
  @@index([userId])
  @@index([userId, organizationId, createdAt(sort: Desc)])
}

