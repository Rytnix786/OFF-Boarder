model EnterpriseConversation {
  id             String                     @id @default(cuid())
  organizationId String?
  subject        String
  contactName    String?
  contactEmail   String?
  companyName    String?
  source         String?                    @default("INTERNAL")
  status         EnterpriseConversationStatus @default(OPEN)
  lastMessageAt  DateTime?
  ipAddress      String?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  organization   Organization?              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages       EnterpriseMessage[]

  @@index([organizationId])
  @@index([ipAddress])
}

model EnterpriseMessage {
  id             String               @id @default(cuid())
  conversationId String
  senderId       String?
  senderType     EnterpriseSenderType
  content        String
  createdAt      DateTime             @default(now())
  conversation   EnterpriseConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

enum EnterpriseConversationStatus {
  OPEN
  CLOSED
}

enum EnterpriseSenderType {
  ORG_USER
  PLATFORM_ADMIN
  EXTERNAL_VISITOR
}
