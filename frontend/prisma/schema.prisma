model UserSession {
  id               String        @id @default(cuid())
  userId           String
  organizationId   String?
  sessionToken     String        @unique
  refreshToken     String?       @unique
  deviceId         String?
  deviceName       String?
  browserName      String?
  browserVersion   String?
  osName           String?
  osVersion        String?
  ipAddress        String?
  userAgent        String?
  city             String?
  country          String?
  authMethod       String?       @default("password")
  rememberDevice   Boolean       @default(false)
  lastActiveAt     DateTime?     @default(now())
  expiresAt        DateTime?
  refreshExpiresAt DateTime?
  revokedAt        DateTime?
  revokedBy        String?
  revokedReason    String?
  passwordVersion  Int?          @default(1)
  roleVersion      Int?          @default(1)
  isCurrent        Boolean       @default(false)
  createdAt        DateTime      @default(now())
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
  @@index([sessionToken])
  @@index([refreshToken])
  @@index([deviceId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model EmployeeSecurityProfile {
  id                String       @id @default(cuid())
  employeeId        String       @unique
  organizationId    String
  isHighRisk        Boolean      @default(false)
  highRiskReason    String?
  highRiskMarkedAt  DateTime?
  highRiskMarkedBy  String?
  isSuspended       Boolean      @default(false)
  suspendedReason   String?
  suspendedAt       DateTime?
  suspendedBy       String?
  suspendedUntil    DateTime?
  isLocked          Boolean      @default(false)
  lockedReason      String?
  lockedAt          DateTime?
  lockedBy          String?
  lastLoginAt       DateTime?
  lastLoginIp       String?
  lastLoginCity     String?
  lastLoginCountry  String?
  lastLoginMethod   String?
  knownIPs          Json?        @default("[]")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  employee          Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([organizationId])
  @@index([isHighRisk])
  @@index([isSuspended])
  @@index([isLocked])
}

model SecurityPolicy {
  id              String       @id @default(cuid())
  organizationId  String
  policyType      String
  name            String
  description     String?
  config          Json         @default("{}")
  isActive        Boolean      @default(true)
  scope           String       @default("ORG_WIDE")
  category        String       @default("OFFBOARDING_ENFORCEMENT")
  severity        String       @default("MEDIUM")
  lastTriggeredAt DateTime?
  triggerCount    Int          @default(0)
  createdBy       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  enforcementLogs PolicyEnforcementLog[]

  @@unique([organizationId, policyType])
  @@index([organizationId])
  @@index([policyType])
  @@index([isActive])
  @@index([category])
}

model PolicyEnforcementLog {
  id             String         @id
  organizationId String
  policyId       String
  policyType     String
  action         String
  status         String         @default("TRIGGERED")
  targetType     String
  targetId       String?
  targetName     String?
  triggeredBy    String?
  details        Json           @default("{}")
  bypassedBy     String?
  bypassReason   String?
  createdAt      DateTime       @default(now())
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  policy         SecurityPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([policyId])
  @@index([createdAt])
}

model PlatformStatus {
