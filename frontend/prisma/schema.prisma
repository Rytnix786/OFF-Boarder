model JoinRequest {
  id                 String            @id @default(cuid())
  organizationId     String
  requesterUserId    String
  requesterEmail     String
  requestedRole      JoinRequestRole
  status             JoinRequestStatus @default(REQUESTED_MEMBER)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  expiresAt          DateTime
  resolvedAt         DateTime?
  resolvedByUserId   String?
  resolutionReason   String?
  policyEvalResult   PolicyEvalResult?
  policyEvalReason   String?
  escalatedAt        DateTime?
  escalationReason   String?
  organization       Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requester          User              @relation("JoinRequestRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  resolvedBy         User?             @relation("JoinRequestResolver", fields: [resolvedByUserId], references: [id])

  @@unique([organizationId, requesterUserId])
