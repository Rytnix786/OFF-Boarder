# Environment Variables Template
# Copy this to .env and fill in your actual values

# Database URLs (use direct PostgreSQL URLs for driver adapter compatibility)
DATABASE_URL=postgresql://postgres:password@localhost:5432/offboarder
DIRECT_DATABASE_URL=postgresql://postgres:password@localhost:5432/offboarder

# Supabase Configuration
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Email Configuration (optional)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@yourdomain.com
ENABLE_EMAIL_NOTIFICATIONS=true

# PostgreSQL Connection Pooling (optional)
PG_POOL_MAX=10
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONNECTION_TIMEOUT_MS=15000
PG_POOL_MAX_USES=500

# Environment
NODE_ENV=development
